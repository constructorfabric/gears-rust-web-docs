{
  "name": "gears.dev",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "Documentation portal for the Gears Rust framework",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "sync": "node scripts/sync-docs.mjs",
    "predev": "npm run sync",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint:md": "markdownlint-cli2",
    "links": "linkinator ./dist --config linkinator.config.json",
    "clean": "rm -rf dist .astro src/content/docs public/synced"
  },
  "dependencies": {
    "@astrojs/starlight": "0.41.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@lunariajs/core": "^0.1.1",
    "astro": "7.0.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "linkinator": "^7.6.1",
    "markdownlint-cli2": "^0.23.0",
    "typescript": "^7.0.2"
  }
}
